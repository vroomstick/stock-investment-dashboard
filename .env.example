# Copy this file to .env and fill in your real values.
# .env is in .gitignore and will never be committed.

# FRED API — free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_key_here

# Reddit API — create an app at https://www.reddit.com/prefs/apps/
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_SECRET=your_secret_here
REDDIT_USER_AGENT=stock-dashboard-mlspec

# Email (Gmail) — use an App Password, not your real password
# Generate one at myaccount.google.com/apppasswords
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_RECIPIENT=recipient@gmail.com
